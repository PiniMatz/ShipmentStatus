# --- Gmail OAuth 2.0 Credentials ---
# Register a Desktop application on Google Cloud Console and enable Gmail API.
GMAIL_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your_google_client_secret

# --- Carrier Tracking API Config ---
# Options: 'mock' (default for testing), 'whereparcel'
TRACKING_PROVIDER=mock

# --- WhereParcel Credentials (Optional, if TRACKING_PROVIDER=whereparcel) ---
WHEREPARCEL_API_KEY=your_whereparcel_api_key
WHEREPARCEL_SECRET_KEY=your_whereparcel_secret_key

# --- 17TRACK Credentials (Optional, for auto-tracking Israel Post, Aramex, etc.) ---
# Get your free token (100 free tracking updates/month) at https://api.17track.net/
17TRACK_API_KEY=your_17track_api_token

# --- Server Config ---
PORT=8080
